# ============================================
# convergio-mcp — Environment Variables
# ============================================

# --- Authentication (required) ---
# API token for MCP server authentication
CONVERGIO_API_TOKEN=your-api-token-here

# --- Infrastructure ---
# URL of the Convergio daemon (default: http://127.0.0.1:7777)
# CONVERGIO_DAEMON_URL=http://127.0.0.1:7777

# --- MCP Configuration ---
# MCP profile name to load
# CONVERGIO_MCP_PROFILE=default

# MCP ring level (e.g., core, extended)
# CONVERGIO_MCP_RING=core
